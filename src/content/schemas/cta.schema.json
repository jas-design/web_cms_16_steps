{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/cta.schema.json",
  "title": "CTA Section Schema",
  "description": "Validation constraints modeling high-conversion Call To Action highlights.",
  "type": "object",
  "properties": {
    "meta": {
      "$ref": "common.schema.json#/definitions/SectionMeta"
    },
    "annotation": {
      "$ref": "common.schema.json#/definitions/LocalizedString"
    },
    "title": {
      "$ref": "common.schema.json#/definitions/LocalizedString"
    },
    "subtitle": {
      "$ref": "common.schema.json#/definitions/LocalizedTextarea"
    },
    "layoutFormat": {
      "type": "string",
      "enum": ["centered", "card-inset", "two-column"],
      "default": "centered"
    },
    "theme": {
      "type": "string",
      "enum": ["dark", "light", "emerald-glass", "interactive-pulse"],
      "default": "dark"
    },
    "ctas": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "$ref": "common.schema.json#/definitions/LinkCTA"
      }
    }
  },
  "required": ["title", "ctas"]
}
